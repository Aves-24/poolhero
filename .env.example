# --- Google Sheets jako baza danych ---
# Jeśli te zmienne NIE są ustawione, aplikacja używa lokalnego pliku .data/db.json
# (działa tylko lokalnie podczas `npm run dev`, NIE na Vercel).

# ID arkusza Google (z adresu URL: /spreadsheets/d/<TO_ID>/edit)
GOOGLE_SHEET_ID=

# E-mail konta serwisowego (Service Account), np. poolhero@projekt.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Klucz prywatny konta serwisowego. Wklej całość w cudzysłowie, ze znakami \n.
# Przykład: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# --- Gemini AI (Google AI Studio) ---
# Pobierz darmowy klucz na: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Logowanie / bezpieczeństwo ---
# Hasło i login do aplikacji. Sprawdzane WYŁĄCZNIE po stronie serwera
# (nigdy nie trafiają do przeglądarki). Jeśli nie ustawisz — domyślnie rafal / Pool123!
APP_LOGIN=rafal
APP_PASSWORD=Pool123!

# Losowy, długi sekret sesji (token ciasteczka). USTAW WŁASNY na Vercel!
# Wygeneruj np. w terminalu:  openssl rand -hex 32
AUTH_SECRET=
