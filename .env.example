# --- Google Sheets jako baza danych ---
# Jeśli te zmienne NIE są ustawione, aplikacja używa lokalnego pliku .data/db.json
# (działa tylko lokalnie podczas `npm run dev`, NIE na Vercel).

# ID arkusza Google (z adresu URL: /spreadsheets/d/<TO_ID>/edit)
GOOGLE_SHEET_ID=

# E-mail konta serwisowego (Service Account), np. poolhero@projekt.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Klucz prywatny konta serwisowego. Wklej całość w cudzysłowie, ze znakami \n.
# Przykład: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# --- Gemini AI (Google AI Studio) ---
# Pobierz darmowy klucz na: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Logowanie przez Google (NextAuth) ---
# Utwórz "OAuth 2.0 Client ID" (typ: Web application) w Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google   (lokalnie)
#   https://TWOJA-DOMENA.vercel.app/api/auth/callback/google   (produkcja)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Losowy, długi sekret sesji NextAuth. Wygeneruj:  openssl rand -hex 32
NEXTAUTH_SECRET=

# Pełny adres aplikacji (produkcja). Lokalnie NextAuth wykryje sam.
#   np. https://poolhero.vercel.app
NEXTAUTH_URL=

# E-mail Twojego konta Google, które ma przejąć istniejące profile
# utworzone przed wprowadzeniem logowania (migracja starych danych).
LEGACY_OWNER_EMAIL=
